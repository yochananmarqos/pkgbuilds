# https://aur.archlinux.org/packages/fresh-editor-bin

pkgname=fresh-editor-bin
_app_id=io.github.sinelaw.fresh
pkgver=0.3.2
pkgrel=1
pkgdesc="A lightweight, fast terminal-based text editor with LSP support and TypeScript plugins"
url="https://getfresh.dev"
license=('GPL-2.0-or-later')
arch=('x86_64' 'aarch64')
depends=(
  'bash'
  'glibc'
  'hicolor-icon-theme'
  'libgcc'
)
optdepends=(
  'bash-language-server: LSP for Bash'
  'clang: LSP for C/C++'
  'csharp-language-server: LSP for C#'  ## AUR
  'gopls: LSP for Go'
  'jdtls: LSP for Java' ## AUR
  'kotlin-language-server: LSP for Kotlin'  ## AUR
  'lua-language-server: LSP for Lua'
  'marksman: LSP for Markdown'
  'pyright: Alternative LSP for Python'
  'python-lsp-server: Default LSP for Python'
  'rust-analyzer: LSP for Rust'
  'texlab: LSP for LaTeX'
  'typescript-language-server: LSP for TypeScript / JavaScript'
  'yaml-language-server: LSP for YAML'
  'zls: LSP for Zig'
)
provides=("${pkgname%-bin}")
conflicts=("${pkgname%-bin}")
source=("fresh-$pkgver.desktop::https://raw.githubusercontent.com/sinelaw/fresh/refs/tags/v$pkgver/crates/${pkgname%-bin}/resources/fresh.desktop"
        "fresh-$pkgver.png::https://raw.githubusercontent.com/sinelaw/fresh/refs/tags/v$pkgver/docs/icons/linux/fresh_512.png"
        "default-$pkgver.json::https://raw.githubusercontent.com/sinelaw/fresh/refs/tags/v$pkgver/crates/${pkgname%-bin}/keymaps/default.json"
        "emacs-$pkgver.json::https://raw.githubusercontent.com/sinelaw/fresh/refs/tags/v$pkgver/crates/${pkgname%-bin}/keymaps/emacs.json"
        "macos-$pkgver.json::https://raw.githubusercontent.com/sinelaw/fresh/refs/tags/v$pkgver/crates/${pkgname%-bin}/keymaps/macos.json"
        "macos-gui-$pkgver.json::https://raw.githubusercontent.com/sinelaw/fresh/refs/tags/v$pkgver/crates/${pkgname%-bin}/keymaps/macos-gui.json"
        "vscode-$pkgver.json::https://raw.githubusercontent.com/sinelaw/fresh/refs/tags/v$pkgver/crates/${pkgname%-bin}/keymaps/vscode.json"
        "config.example-$pkgver.json::https://raw.githubusercontent.com/sinelaw/fresh/refs/tags/v$pkgver/crates/${pkgname%-bin}/config.example.json")
source_x86_64=("https://github.com/sinelaw/fresh/releases/download/v$pkgver/${pkgname%-bin}-x86_64-unknown-linux-gnu.tar.xz")
source_aarch64=("https://github.com/sinelaw/fresh/releases/download/v$pkgver/${pkgname%-bin}-aarch64-unknown-linux-gnu.tar.xz")
sha256sums=('4eb634ff78203b07d5d4347322fbcd9714221611014c369204b5f85286fb8761'
            '3526fb87a9b1ee3e91cd587accb2c9775ffbf1dccebb1ad9cf4f4c07580dd2a2'
            '40a639cc5c4fa451b2cfad6715c73278315f150d26028d2ef95551f22ee19411'
            'b093e1e5fdde6ccb1c0b542e4f9662166fa088a239f743463deed6be0edb2f3f'
            '35dfa1fe22783166766ed6181115f054745dfe91e1c87b8bbf9da9036f9177a2'
            '68e03aae69baebeab0524aa19161d8132cb340a3e7be60d03c0cecf70d654dcd'
            '1d516c2b9b02baded30f08be11f50c5b3ec95c80a37a4971bfd2b99a435d2f4a'
            'd3afe18c5fabff495625113ab8e6d2265c9b1121a8f23071fc90c261f1a8f070')
sha256sums_x86_64=('bc29a47459fe63451b31b3406c671e28acf89fd7a4e66741759a5dc7177c9465')
sha256sums_aarch64=('a4a6e8bb22309ac123a69cd39d57d92fe5ee87da9e0d253c2d020b1a01b1575f')

package() {
  cd "${pkgname%-bin}-${CARCH}-unknown-linux-gnu"
  install -Dm755 fresh "$pkgdir/usr/share/${pkgname%-bin}/fresh"
  cp -r plugins themes "$pkgdir/usr/share/fresh-editor/"

  install -d "$pkgdir/usr/bin"
  ln -s "/usr/share/${pkgname%-bin}/fresh" "$pkgdir/usr/bin/fresh"

  install -Dm644 README.md -t "$pkgdir/usr/share/doc/$pkgname/"
  install -Dm644 "$srcdir/fresh-$pkgver.desktop" \
    "$pkgdir/usr/share/applications/fresh.desktop"
  install -Dm644 "$srcdir/fresh-$pkgver.png" \
    "$pkgdir/usr/share/icons/hicolor/512x512/apps/fresh.png"
  install -Dm644 "$srcdir/config.example-$pkgver.json" -t \
    "$pkgdir/usr/share/doc/$pkgname/"

  for f in default emacs macos macos-gui vscode; do
    install -Dm644 "$srcdir/${f}-$pkgver.json" \
      "$pkgdir/usr/share/fresh-editor/keymaps/${f}.json"
  done
}
