# https://aur.archlinux.org/packages/fzf-tab

pkgname=fzf-tab
pkgver=1.3.0
pkgrel=1
pkgdesc="Replace zsh's default completion selection menu with fzf"
arch=('any')
url="https://github.com/Aloxaf/fzf-tab"
license=('MIT')
depends=(
  'fzf'
  'zsh'
)
makedepends=('git')
source=("git+https://github.com/Aloxaf/fzf-tab.git#tag=v${pkgver}")
sha256sums=('8ee0b65ef4c97d738a1fdb5f5c6ad2e1e91d54407f3bc6a457ea1d88656278e9')

check() {
  cd "${pkgname}"

  pushd test
  ZTST_verbose=1 zsh -f ./runtests.zsh fzftab.ztst
  popd
}

package() {
  cd "${pkgname}"
  install -Dm644 "${pkgname}".{plugin.zsh,zsh} -t \
    "${pkgdir}/usr/share/zsh/plugins/${pkgname}/"
  cp -dr --no-preserve=ownership lib "${pkgdir}/usr/share/zsh/plugins/${pkgname}/"
  install -Dm644 LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}/"
}
