# https://aur.archlinux.org/packages/efibooteditor

pkgname=efibooteditor
pkgver=1.5.7
pkgrel=1
pkgdesc="Boot Editor for (U)EFI based systems"
arch=('x86_64')
url="https://github.com/Neverous/efibooteditor"
license=('LGPL-3.0-or-later')
depends=(
  'efivar'
  'polkit'
  'qt6-base'
  'qt6-svg'
)
makedepends=(
  'cmake'
  'desktop-file-utils'
  'git'
  'qt6-tools'
)
source=("git+https://github.com/Neverous/efibooteditor.git#tag=v$pkgver?signed")
sha256sums=('e9dd6122e2cc6453960ccec12a6a67ded6202703caf8c53e29d55ae8389c3dc9')
validpgpkeys=('9E76A390AAF9772C8448DCCEE4F948F71FEE7375') # Maciej Szeptuch <neverous@neverous.info>

prepare() {
  cd "$pkgname"

  # Set StartupWMClass
  desktop-file-edit --set-key=StartupWMClass --set-value="EFI Boot Editor" \
    misc/EFIBootEditor.desktop
}

build() {
  export BUILD_VERSION="$pkgver"
  cmake -B build -S "$pkgname" \
    -DCMAKE_BUILD_TYPE='RelWithDebInfo' \
    -DCMAKE_INSTALL_PREFIX='/usr' \
    -DQT_VERSION_MAJOR='6' \
    -Wno-dev
  cmake --build build
}

check() {
  ctest --test-dir build --output-on-failure --parallel $(nproc)
}

package() {
  DESTDIR="$pkgdir" cmake --install build

  rm -v "$pkgdir/usr/AppRun"
}
