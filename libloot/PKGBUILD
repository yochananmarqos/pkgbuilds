# https://aur.archlinux.org/packages/libloot

pkgname=libloot
pkgver=0.29.4
pkgrel=1
pkgdesc="A C++ library for accessing LOOT's metadata and sorting functionality."
arch=('x86_64')
url="https://loot.github.io"
license=('GPL-3.0-only')
depends=(
  'libgcc'
  'libstdc++'
)
makedepends=(
  'cargo'
  'cmake'
#  'doxygen'  # docs
  'git'
#  'python-breathe'  # docs
#  'python-sphinx'  # docs
#  'python-sphinx_rtd_theme'  # docs
)
source=("git+https://github.com/loot/libloot.git#tag=$pkgver")
sha256sums=('e9b3c688827458846d9f41fb8805f81169cb866510363a6a72d7a37a2b75f92e')

prepare() {
  cd "$pkgname"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --target host-tuple
}

build() {
  cd "$pkgname"
  export RUSTUP_TOOLCHAIN=stable
  local cmake_options=(
    -B build
    -S cpp
    -W no-dev
    -D CMAKE_BUILD_TYPE='RelWithDebInfo'
    -D CMAKE_INSTALL_PREFIX='/usr'
    -D LIBLOOT_BUILD_TESTS='OFF'
    -D LIBLOOT_INSTALL_DOCS='OFF'
  )
  cmake "${cmake_options[@]}"
  cmake --build build

  # docs
#  sphinx-build -b html docs build/docs/html
}

package() {
  cd "$pkgname"
  DESTDIR="$pkgdir" cmake --install build
}
