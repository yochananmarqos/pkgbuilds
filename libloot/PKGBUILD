# https://aur.archlinux.org/packages/libloot
# https://aur.archlinux.org/packages/python-libloot

pkgname=(
  'libloot'
  'python-libloot'
)
pkgbase=libloot
pkgver=0.29.6
pkgrel=1
pkgdesc="A C++ library for accessing LOOT's metadata and sorting functionality."
arch=('x86_64')
url="https://github.com/loot/libloot"
license=('GPL-3.0-only')
depends=(
  'libgcc'
  'libstdc++'
)
makedepends=(
  'cargo'
  'cmake'
  'git'
  'maturin'
  'python-installer'
)
source=("git+https://github.com/loot/libloot.git#tag=$pkgver")
sha256sums=('812f0bc5a7f612689d8943e02149b1d6306ea8c8afef2fe628c857fa522d76a9')

prepare() {
  cd "$pkgbase"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --target host-tuple
  cargo fetch --manifest-path python/Cargo.toml --target host-tuple
}

build() {
  cd "$pkgbase"
  export RUSTUP_TOOLCHAIN=stable
  local cmake_options=(
    -B build
    -S cpp
    -W no-dev
    -D CMAKE_BUILD_TYPE='RelWithDebInfo'
    -D CMAKE_INSTALL_PREFIX='/usr'
    -D LIBLOOT_BUILD_TESTS='OFF'
    -D LIBLOOT_INSTALL_DOCS='OFF'
  )
  cmake "${cmake_options[@]}"
  cmake --build build

  export CARGO_TARGET_DIR=target
  maturin build --manifest-path python/Cargo.toml --release
}

package_libloot() {
  cd "$pkgbase"
  DESTDIR="$pkgdir" cmake --install build
}

package_python-libloot() {
  pkgdesc="An experimental Python wrapper around libloot"
  depends=(
    'libloot'
    'python'
  )

  cd "$pkgbase"
  python -m installer --destdir="$pkgdir" target/wheels/*.whl
}
