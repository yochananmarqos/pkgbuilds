# https://aur.archlinux.org/packages/r2modman-bin

pkgname=r2modman-bin
pkgver=3.2.17
pkgrel=1
pkgdesc="A simple and easy to use mod manager for several games using Thunderstore."
arch=('x86_64')
url="https://github.com/ebkr/r2modmanPlus"
license=('MIT')
depends=(
  'alsa-lib'
  'gtk3'
  'nss'
)
provides=("${pkgname%-bin}")
conflicts=("${pkgname%-bin}")
source=("${url}/releases/download/v$pkgver/${pkgname%-bin}-$pkgver.pacman"
        "LICENSE-upstream::https://raw.githubusercontent.com/ebkr/r2modmanPlus/refs/tags/v$pkgver/LICENSE")
noextract=("${pkgname%-bin}-$pkgver.pacman")
sha256sums=('ba5fb76ea6238cb301a3d0b0f0336849fc66008f3a1b20b8f7b2291a483fb7b4'
            'ab4643c18a58edee5b0beac8278517f6475b2956d5999b40e3176297b9a0ce18')

prepare() {
  mkdir -p "${pkgname%-bin}-$pkgver"
  bsdtar xf "${pkgname%-bin}-$pkgver.pacman" -C "${pkgname%-bin}-$pkgver"
}

package() {
  cd "${pkgname%-bin}-$pkgver"
  cp -a opt usr "$pkgdir/"
  install -Dm644 "$srcdir/LICENSE-upstream" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

  install -d "$pkgdir/usr/bin"
  ln -sf "/opt/${pkgname%-bin}/${pkgname%-bin}" "$pkgdir/usr/bin/${pkgname%-bin}"
}
