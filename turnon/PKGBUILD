# https://aur.archlinux.org/packages/turnon

pkgname=turnon
_app_id="de.swsnr.${pkgname}"
pkgver=3.1.2
pkgrel=1
pkgdesc="Turn on devices in your local network"
arch=('x86_64')
url="https://codeberg.org/swsnr/turnon"
license=('EUPL-1.2')
depends=(
  'dconf'
  'glib2'
  'gtk4'
  'hicolor-icon-theme'
  'libadwaita'
  'libgcc'
)
makedepends=(
  'git'
  'blueprint-compiler'
  'cargo'
  'just'
)
checkdepends=(
  'appstream'
  'desktop-file-utils'
)
source=("git+https://codeberg.org/swsnr/turnon.git#tag=v${pkgver}"
        'schemas.patch')
sha256sums=('709c63f56be2a5ba22f244fc78dc20447682260745ba4550a1f149b5d3c23ae2'
            '5ab8c215dbe7d8daf61b7320c81ee16bc98c80c0b032a6e011699083ecdb8c60')

prepare() {
  cd "${pkgname}"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target host-tuple

  # Don't compile schemas after installation
  patch -Np1 -i ../schemas.patch
}

build() {
  cd "${pkgname}"
  export RUSTUP_TOOLCHAIN=stable
  just APPID="${_app_id}" compile
  cargo build --frozen --release
}

check() {
  cd "${pkgname}"
  export RUSTUP_TOOLCHAIN=stable
  cargo test --frozen

  appstreamcli validate --no-net "${_app_id}.metainfo.xml"
  desktop-file-validate "${_app_id}.desktop"
}

package() {
	cd "${pkgname}"
	just APPID="${_app_id}" DESTPREFIX="${pkgdir}/usr" install

  ln -s "/usr/bin/${_app_id}" "${pkgdir}/usr/bin/${pkgname}"

  install -Dm644 LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}/"
}
