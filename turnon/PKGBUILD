# https://aur.archlinux.org/packages/turnon

pkgname=turnon
_app_id="de.swsnr.${pkgname}"
pkgver=3.0.4
pkgrel=1
pkgdesc="Turn on devices in your local network"
arch=('any')
url="https://codeberg.org/swsnr/turnon"
license=('EUPL-1.2')
depends=(
  'dconf'
  'glib2'
  'gtk4'
  'hicolor-icon-theme'
  'libadwaita'
  'python-gobject'
  'python-packaging'
)
makedepends=(
  'git'
  'blueprint-compiler'
  'python-build'
  'python-hatchling'
  'python-installer'
  'python-wheel'
)
checkdepends=(
  'appstream'
  'desktop-file-utils'
  'python-pytest'
  'python-pytest-asyncio'
)
source=("git+https://codeberg.org/swsnr/turnon.git#tag=v${pkgver}")
sha256sums=('1bf37b5bb0b6e0e799bfd2155ec73fc62d0e1796890f7b61cf0192a13d715388')

prepare() {
  cd "${pkgname}"
  git clean -dfx
}

build() {
	cd "${pkgname}"

  # Skip dependency check as it can't find blueprint-compiler
  # even though we have it
	python -m build --wheel --skip-dependency-check --no-isolation
}

check() {
	cd "${pkgname}"
  python -m venv --clear --without-pip --system-site-packages test-env
  test-env/bin/python -m installer dist/*.whl
  test-env/bin/python -m pytest

  appstreamcli validate --no-net "${_app_id}.metainfo.xml"
  desktop-file-validate "${_app_id}.desktop"
}

package() {
	cd "${pkgname}"
	python -m installer --destdir="${pkgdir}" dist/*.whl

  ln -s "/usr/bin/${_app_id}" "${pkgdir}/usr/bin/${pkgname}"

  install -Dm644 LICENSE -t "${pkgdir}/usr/share/licenses/${pkgname}/"
}
