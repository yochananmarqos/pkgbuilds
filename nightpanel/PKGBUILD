# https://aur.archlinux.org/packages/dailydriver

## WIP (What a mess. Thanks, for the help, Claude 🙄)

pkgname=(
  'nightpanel'
  'gnome-shell-extension-nightpanel'
)
pkgbase=nightpanel
_uuid="$pkgbase@$pkgbase"
pkgver=0.2.1
pkgrel=1
pkgdesc="Visual keyboard shortcut configuration for GNOME"
arch=('any')
url="https://github.com/gregfelice/nightpanel"
license=('GPL-3.0-or-later')
depends=(
  'dconf'
  'gtk4'
  'libadwaita'
  'python-annotated-types'
  'python-gobject'
  'python-pydantic'
  'python-tomli-w'
  'python-typing_extensions'
)
makedepends=(
  'gnome-shell'
  'meson'
)
checkdepends=(
  'python-pytest'
  'python-pytest-cov'
  'python-pytest-mock'
)
source=("$pkgbase-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('332a5639370a426bf2f8721040ba2168d06f64618a14881508107561926a9e48')

prepare() {
  cd "$pkgbase-$pkgver"
  sed -i 's/DailyDriver/Nightpanel/' data/icons/meson.build

  sed -i 's/.local/usr/g' "src/$pkgbase/services/tiling_service.py"
}

build() {
  arch-meson "$pkgbase-$pkgver" build
  meson compile -C build

  cd "$pkgbase-$pkgver"
  gnome-extensions pack "src/$pkgbase/shell-extension/${_uuid}" --force
}

check() {
  meson test -C build --no-rebuild --print-errorlogs

  cd "$pkgbase-$pkgver"
  PYTHONPATH=src pytest tests/unit/ || :
}

package_nightpanel() {
  optdepends=('gnome-shell-extension-tiling-assistant: Tiling Assistant shortcut support')
  conflicts=('dailydriver')

  meson install -C build --no-rebuild --destdir "$pkgdir"
}

package_gnome-shell-extension-nightpanel() {
  pkgdesc="Companion to Nightpanel"
  depends=(
    'nightpanel'
    'gnome-shell'
  )
  conflicts=('gnome-shell-extension-dailydriver-cheatsheet')

  cd "$pkgbase-$pkgver"
  install -d "$pkgdir/usr/share/gnome-shell/extensions/${_uuid}"
  bsdtar -xvf "${_uuid}.shell-extension.zip" -C \
    "$pkgdir/usr/share/gnome-shell/extensions/${_uuid}/" --no-same-owner
}
