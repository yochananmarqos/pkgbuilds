# https://aur.archlinux.org/packages/fresh-editor

pkgname=fresh-editor
_app_id=io.github.sinelaw.fresh
pkgver=0.3.12
pkgrel=2
pkgdesc="A lightweight, fast terminal-based text editor with LSP support and TypeScript plugins"
url="https://getfresh.dev"
license=('GPL-2.0-only')
arch=('x86_64' 'aarch64')
depends=(
  'bash'
  'glibc'
  'hicolor-icon-theme'
  'libgcc'
)
makedepends=(
  'cargo'
  'clang'
  'git'
)
checkdepends=(
  'cargo-nextest'
  'desktop-file-utils'
  'libxkbcommon-x11'
  'mesa'
  'python'
  'vulkan-icd-loader'
  'xorg-server-xvfb'
)
optdepends=(
  'bash-language-server: LSP for Bash'
  'clang: LSP for C/C++'
  'csharp-language-server: LSP for C#'  ## AUR
  'gopls: LSP for Go'
  'jdtls: LSP for Java' ## AUR
  'kotlin-language-server: LSP for Kotlin'  ## AUR
  'lua-language-server: LSP for Lua'
  'marksman: LSP for Markdown'
  'pyright: Alternative LSP for Python'
  'python-lsp-server: Default LSP for Python'
  'rust-analyzer: LSP for Rust'
  'texlab: LSP for LaTeX'
  'typescript-language-server: LSP for TypeScript / JavaScript'
  'yaml-language-server: LSP for YAML'
  'zls: LSP for Zig'
)
source=("git+https://github.com/sinelaw/fresh.git#tag=v$pkgver")
sha256sums=('b1b33207990b8c88dbeb2404a9853f5ab6f8a40ef4a12fe157005a0cd0695e78')

prepare() {
  cd fresh
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target host-tuple
}

build() {
  cd fresh
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  export CC=clang

  # Enable all features to build experimental GUI
  cargo build --frozen --release --all-features
}

check() {
  cd fresh
  export RUSTUP_TOOLCHAIN=stable
  export LIBGL_ALWAYS_SOFTWARE=1
  export WGPU_BACKEND=vulkan

  # 6929 tests run: 6926 passed, 2 failed, 1 timed out, 141 skipped
  xvfb-run cargo nextest run \
    -j=4 \
    --no-fail-fast \
    --frozen \
    --all-features \
    --all-targets || :

  desktop-file-validate "crates/$pkgname/resources/fresh-gui.desktop"
}

package() {
  cd fresh
  install -Dm755 target/release/fresh -t "$pkgdir/usr/bin/"
  install -Dm644 "crates/$pkgname/resources/fresh-gui.desktop" \
    "$pkgdir/usr/share/applications/fresh.desktop"

  for i in docs/icons/linux/hicolor/*/apps/fresh.png; do
    size=$(basename $(dirname $(dirname "${i}")))
    install -Dm644 "${i}" "$pkgdir/usr/share/icons/hicolor/${size}/apps/fresh.png"
  done

  install -Dm644 README.md -t "$pkgdir/usr/share/doc/$pkgname/"
  install -Dm644 "crates/$pkgname/config.example.json" -t \
    "$pkgdir/usr/share/doc/$pkgname/"
}
