# https://aur.archlinux.org/packages/dusklight

pkgname=dusklight
_app_id=dev.twilitrealm.dusk
pkgver=1.4.1
pkgrel=1
pkgdesc="A reverse-engineered reimplementation of Twilight Princess."
arch=('x86_64')
url="https://twilitrealm.dev"
license=('CC0-1.0')
depends=(
  'abseil-cpp'
  'fmt'
  'freetype2'
  'glibc'
  'hicolor-icon-theme'
  'libgcc'
  'libjpeg-turbo'
  'libpng'
  'libstdc++'
  'sdl3'
  'sqlite'
  'zlib'
)
makedepends=(
  'cmake'
  'git'
  'meson'
  'ninja'
  'vulkan-headers'
)
checkdepends=('desktop-file-utils')
conflicts=('tp-dusk')
source=("git+https://github.com/TwilitRealm/dusklight.git#tag=v$pkgver"
        "git+https://github.com/encounter/aurora.git")
sha256sums=('90920dafb86c6453c883d7e103814cb139f6368909eee1cedf3de9258269b5da'
            'SKIP')

prepare() {
  cd "$pkgname"
  git submodule init
  git config submodule.extern/aurora.url "$srcdir/aurora"
  git -c protocol.file.allow=always submodule update
}

build() {
  local cmake_options=(
    -B build
    -S "$pkgname"
    -G Ninja
    -W no-dev
    -D CMAKE_BUILD_TYPE='RelWithDebInfo'
    -D CMAKE_INSTALL_PREFIX="/opt/$pkgname"
    -D CMAKE_MSVC_RUNTIME_LIBRARY='MultiThreaded'
    -D DUSK_ENABLE_UPDATE_CHECKER='OFF'
    -D AURORA_SDL3_PROVIDER='system'
    -D AURORA_SDL3_LINKAGE='shared'
  )
  cmake "${cmake_options[@]}"
  cmake --build build
}

check() {
  cd "$pkgname"
  desktop-file-validate "platforms/freedesktop/${_app_id}.desktop"
}

package() {
  DESTDIR="$pkgdir" cmake --install build

  install -Dm755 build/librmlui.so -t "${pkgdir}/opt/$pkgname/"
  install -Dm755 build/libs/freeverb/libfreeverb.so -t "${pkgdir}/opt/$pkgname/"

  install -d "$pkgdir/usr/bin"
  ln -s "/opt/$pkgname/$pkgname" "$pkgdir/usr/bin/"

  cd "$pkgname"
  install -Dm644 "platforms/freedesktop/${_app_id}.desktop" -t \
    "$pkgdir/usr/share/applications/"
  install -Dm644 README.md -t "$pkgdir/usr/share/doc/$pkgname/"

  for i in 16 32 48 64 128 256 512 1024; do
    install -Dm644 "platforms/freedesktop/${i}x${i}/apps/${_app_id}.png" -t \
      "$pkgdir/usr/share/icons/hicolor/${i}x${i}/apps/"
  done
}
